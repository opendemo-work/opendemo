{
  "version": "1.0.0",
  "description": "OpenDemo 命令风险分级规则。匹配按优先级从高到低：high > medium > low。",
  "levels": {
    "high": {
      "badge": "🔴 高风险",
      "color": "🔴",
      "description": "可能造成数据丢失、服务中断、权限提升或不可逆破坏。",
      "patterns": [
        "rm\\s+-rf?",
        "rm\\s+-f",
        "rm\\s+--recursive",
        "dd\\s+if=",
        "fdisk",
        "mkfs\\.",
        "parted",
        "pvcreate",
        "vgremove",
        "lvremove",
        "mkfs\\s+-t",
        "mkfs\\s+-ext",
        "iptables\\s+-F",
        "iptables\\s+-X",
        "ufw\\s+--force",
        "ufw\\s+reset",
        "halt\\b",
        "reboot\\b",
        "shutdown\\b",
        "poweroff\\b",
        "curl\\s+.*\\|\\s*(ba)?sh",
        "curl\\s+.*\\|\\s*sh",
        "wget\\s+.*\\|\\s*(ba)?sh",
        "wget\\s+.*\\|\\s*sh",
        "docker\\s+system\\s+prune",
        "docker\\s+rm\\s+.*-f",
        "docker\\s+rmi\\s+.*-f",
        "kubectl\\s+delete\\s+.*--all",
        "kubectl\\s+delete\\s+.*--all-namespaces",
        "kubectl\\s+delete\\s+namespace",
        "kubectl\\s+delete\\s+ns\\b",
        "kubectl\\s+delete\\s+crd",
        "kubectl\\s+delete\\s+.*-A",
        "DROP\\s+DATABASE",
        "DROP\\s+TABLE",
        "DELETE\\s+FROM",
        "TRUNCATE\\s+TABLE",
        "drop\\s+database",
        "drop\\s+table",
        "delete\\s+from",
        "truncate\\s+table",
        "helm\\s+uninstall",
        "helm\\s+delete",
        "terraform\\s+destroy",
        "ansible-playbook.*--check.*false",
        "systemctl\\s+(restart|stop|disable)",
        "service\\s+\\w+\\s+(restart|stop)",
        "killall\\b",
        "pkill\\b",
        "setenforce\\s+0",
        "chmod\\s+777",
        "chmod\\s+.*\/etc",
        "chown\\s+-R",
        "usermod\\s+-aG",
        "passwd\\b",
        "userdel\\b",
        "groupdel\\b",
        "kubectl\\s+delete\\b"
      ],
      "notes": [
        "会删除/格式化/停止关键资源，生产环境慎用。",
        "执行前请确认目标范围，建议在隔离测试环境验证。",
        "涉及数据操作前请备份，涉及服务操作前请通知相关人员。"
      ]
    },
    "medium": {
      "badge": "🟡 中风险",
      "color": "🟡",
      "description": "会修改系统状态、安装软件或启动/停止服务，但影响范围相对可控。",
      "patterns": [
        "sudo\\s+",
        "docker\\s+run",
        "docker\\s+build",
        "docker\\s+compose\\s+(up|down|restart)",
        "docker\\s+exec",
        "docker\\s+network\\s+(create|rm)",
        "docker\\s+volume\\s+(create|rm)",
        "kubectl\\s+apply",
        "kubectl\\s+create",
        "kubectl\\s+set",
        "kubectl\\s+scale",
        "kubectl\\s+rollout",
        "kubectl\\s+patch",
        "kubectl\\s+label",
        "kubectl\\s+annotate",
        "kubectl\\s+taint",
        "helm\\s+install",
        "helm\\s+upgrade",
        "helm\\s+rollback",
        "terraform\\s+apply",
        "terraform\\s+plan",
        "ansible-playbook",
        "ansible",
        "systemctl\\s+(start|enable)",
        "service\\s+\\w+\\s+start",
        "apt\\s+(install|remove|update|upgrade)",
        "yum\\s+(install|remove|update)",
        "dnf\\s+(install|remove|update)",
        "pacman\\s+-S",
        "brew\\s+install",
        "pip\\s+install",
        "npm\\s+install",
        "go\\s+install",
        "make\\s+install",
        "make\\s+build",
        "cmake",
        "./configure",
        "mkdir\\s+-p",
        "cp\\s+-r",
        "cp\\s+-f",
        "mv\\s+",
        "tar\\s+.*-x",
        "unzip\\b",
        "mount\\b",
        "umount\\b",
        "ip\\s+link\\s+set",
        "ip\\s+addr\\s+add",
        "ifconfig\\s+.*(up|down)",
        "route\\s+add",
        "sysctl\\s+-w",
        "echo\\s+.*>>\\s*/etc",
        "sed\\s+-i\\s+.*\/etc",
        "firewall-cmd",
        "ufw\\s+(allow|deny|enable|disable)",
        "setfacl",
        "chmod\\s+",
        "chown\\s+",
        "git\\s+clone",
        "git\\s+push",
        "git\\s+pull",
        "git\\s+checkout\\s+-b",
        "git\\s+reset",
        "git\\s+revert",
        "git\\s+stash\\s+drop",
        "ssh\\s+",
        "scp\\s+",
        "rsync\\s+.*--delete",
        "rsync\\s+-avz",
        "curl\\s+.*-O",
        "wget\\s+",
        "python\\s+.*\\.py",
        "go\\s+run",
        "node\\s+",
        "java\\s+-jar",
        "mvn\\s+",
        "gradle\\b",
        "pytest\\b",
        "npm\\s+run",
        "yarn\\s+",
        "pnpm\\s+",
        "\\./scripts/(start|stop|check|run|demo|teardown)\\.sh\\b",
        "\\./[\\w./-]+\\.sh\\b",
        "bash\\s+[\\w./-]+\\.sh\\b",
        "sh\\s+[\\w./-]+\\.sh\\b",
        "source\\s+[\\w./-]+\\.sh\\b",
        "opendemo\\s+new\\b"
      ],
      "notes": [
        "会修改本地环境或启动服务，建议在测试/开发环境先验证。",
        "注意检查依赖版本、端口占用和目标资源配置。",
        "生产环境执行前请经过变更评审和备份确认。"
      ]
    },
    "low": {
      "badge": "🟢 低风险",
      "color": "🟢",
      "description": "只读查询或无害信息展示，不会修改系统状态。",
      "patterns": [
        "^\\s*(#|//)",
        "^\\s*\\$\\s*",
        "ls\\b",
        "ll\\b",
        "cat\\b",
        "echo\\b",
        "pwd\\b",
        "cd\\b",
        "grep\\b",
        "find\\b",
        "head\\b",
        "tail\\b",
        "less\\b",
        "more\\b",
        "wc\\b",
        "sort\\b",
        "uniq\\b",
        "which\\b",
        "whereis\\b",
        "whoami\\b",
        "id\\b",
        "date\\b",
        "uname\\b",
        "hostname\\b",
        "env\\b",
        "printenv\\b",
        "kubectl\\s+get",
        "kubectl\\s+describe",
        "kubectl\\s+logs",
        "kubectl\\s+top",
        "kubectl\\s+explain",
        "docker\\s+ps",
        "docker\\s+images",
        "docker\\s+info",
        "docker\\s+inspect",
        "docker\\s+logs",
        "git\\s+status",
        "git\\s+log",
        "git\\s+branch",
        "git\\s+diff",
        "git\\s+show",
        "git\\s+remote\\s+-v",
        "python\\s+--version",
        "go\\s+version",
        "node\\s+--version",
        "java\\s+--version",
        "mvn\\s+-version",
        "docker\\s+--version",
        "kubectl\\s+version",
        "helm\\s+version"
      ],
      "notes": [
        "通常为只读操作，不会修改系统状态。",
        "可安全地在学习环境中执行。"
      ]
    }
  },
  "excluded_patterns": [
    "^\\s*#",
    "^\\s*\\$\\s*",
    "^\\s*>",
    "^\\s*<",
    "^\\s*\\[",
    "example\\.com",
    "your-",
    "my-",
    "TODO",
    "FIXME"
  ]
}
